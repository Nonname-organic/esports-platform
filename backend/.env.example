# App
ENVIRONMENT=demo
DEBUG=false

# Security (32文字以上のランダム文字列)
SECRET_KEY=change-me-to-a-random-256bit-secret-key-here

# Database (RDS エンドポイント)
DB_HOST=your-rds-endpoint.ap-northeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=esports_db
DB_USER=esports_user
DB_PASSWORD=your-secure-password

# Redis (Docker Compose内はコンテナ名)
REDIS_HOST=redis
REDIS_PORT=6379

# AWS
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=esports-assets-your-account-id
SQS_MATCH_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789/match-queue
SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789/notification-queue

# Discord (任意)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# CORS (フロントエンドのURL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Sentry (任意)
SENTRY_DSN=
